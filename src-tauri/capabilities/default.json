{
  "$schema": "https://schema.tauri.app/config/2.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "autostart:default",
    "dialog:default",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "core:event:default",
    "core:window:default",
    "shell:default",
    "fs:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
