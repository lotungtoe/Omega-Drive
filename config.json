{
  "backup": {
    "enabled": false,
    "snapshot_interval_days": 7
  },
  "data": {
    "folders_file": "folders.json",
    "history_file": "file_history.json",
    "sessions_file": "upload_sessions.json"
  },
  "download": {
    "d3d11_adapter": "NVIDIA GeForce RTX 4060 Laptop GPU",
    "http_timeout_s": 600,
    "large_file_threshold_mb": 500,
    "part_delay_ms": 150,
    "retry_base_delay_s": 2,
    "retry_count": 3,
    "stream_buffer_kb": 640
  },
  "logging": {
    "feature_enabled": {
      "diagnostics": true,
      "download": true,
      "drive": true,
      "player": true,
      "settings": true,
      "upload": true
    },
    "frontend_enabled": true
  },
  "providers": {
    "discord": {
      "limits": {
        "file_limit_bytes": 9437184,
        "file_limit_mb": 9,
        "hard_limit_bytes": 9437184,
        "hard_limit_mb": 9
      },
      "retry": {
        "retry_base_delay_s": 2,
        "send_retries": 3
      },
      "transfer": {
        "batch_size": 2,
        "chunk_mb": 10,
        "parallel_sends": 4
      }
    },
    "telegram": {
      "limits": {
        "file_limit_bytes": 62914560,
        "file_limit_mb": 60,
        "hard_limit_bytes": 0
      },
      "retry": {
        "retry_base_delay_s": 2,
        "send_retries": 3
      },
      "transfer": {
        "batch_size": 1,
        "chunk_mb": 20,
        "parallel_sends": 3
      }
    }
  },
  "ram": {
    "gc_interval_minutes": 10,
    "max_total_upload_mb": 2048,
    "session_ttl_minutes": 60,
    "trash_ttl_days": 30
  },
  "server": {
    "auto_sync_interval_s": 10,
    "host": "0.0.0.0",
    "keep_alive_s": 600,
    "log_level": "info",
    "max_concurrency": 5,
    "port": 8000
  },
  "startup": {
    "auto_sync": true,
    "launch_on_boot": false,
    "persistent_video_bridge": true
  },
  "ui": {
    "dark_mode": true,
    "language": "vi"
  },
  "upload": {
    "general": {
      "chunk_mb": 10,
      "parallel_sends": 3,
      "zip_level": 0
    },
    "upload_mode": "speed"
  }
}